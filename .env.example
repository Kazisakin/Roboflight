# ──────────────────────────────────────────────────────────────
# RoboFlight — Environment Variables
# Copy this file to .env.local for local dev, or add these
# variables in Vercel Dashboard → Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

# SMTP — used by the contact form API (/api/contact)
# For Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# The email address that receives contact form submissions
CONTACT_EMAIL=your-gmail@gmail.com
